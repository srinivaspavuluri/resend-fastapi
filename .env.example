# Copy this file to .env and fill in your values
# NEVER commit .env to git — it contains your real API key

# ── Required ───────────────────────────────────────────────────────────────────

# Get this from resend.com → API Keys
RESEND_API_KEY=re_your_actual_key_here

# ── Optional ───────────────────────────────────────────────────────────────────

# Database — defaults to local SQLite (fine for dev, use PostgreSQL for production)
# SQLite (default, no extra setup):
DATABASE_URL=sqlite+aiosqlite:///./resend_local.db
# PostgreSQL (production — uncomment and fill in):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/resend_db

# Webhook signing secret — copy from Resend dashboard → Webhooks → your endpoint
# If not set, signature verification is skipped (OK for local dev, NOT for production)
# WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Set to "true" to enable SQL query logging (development only — logs contact data!)
DEBUG=false
